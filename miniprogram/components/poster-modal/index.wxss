.poster-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 950;
}

.poster-body {
  width: 700rpx;
  max-height: 90vh;
  background: #fff;
  border-radius: 28rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.poster-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #eee;
  flex-shrink: 0;
}

.poster-title {
  font-size: 32rpx;
  font-weight: 600;
}

.poster-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.poster-scroll {
  flex: 1;
  min-height: 200rpx;
  max-height: 60vh;
  padding: 0 4rpx;
}

.poster-image {
  width: 100%;
  display: block;
  border-radius: 12rpx;
}

.poster-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
  color: var(--text-light);
}

/* ===== Poster Card (fallback) ===== */
.poster-card {
  position: relative;
  width: 100%;
  background: #FFFDF9;
  padding: 36rpx 32rpx 36rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* Top */
.pc-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.pc-top-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.pc-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 1rpx solid var(--border);
}

.pc-avatar image {
  width: 100%;
  height: 100%;
}

.pc-nickname {
  font-size: 28rpx;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.pc-date {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 32rpx;
  letter-spacing: 2rpx;
}

.pc-badge {
  font-size: 24rpx;
  color: #fff;
  padding: 6rpx 24rpx;
  border-radius: 32rpx;
  letter-spacing: 4rpx;
}

/* Score */
.pc-score-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.pc-score-ring {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 3rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
}

.pc-score-num {
  font-size: 64rpx;
  letter-spacing: -2rpx;
}

.pc-score-label {
  font-size: 26rpx;
  color: var(--text-light);
  letter-spacing: 6rpx;
}

/* Dimensions */
.pc-dims {
  background: rgba(123, 97, 255, 0.03);
  border-radius: 20rpx;
  padding: 18rpx 18rpx 6rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(123, 97, 255, 0.06);
}

.pc-dim-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.pc-dim-icon {
  font-size: 26rpx;
  width: 40rpx;
  text-align: center;
}

.pc-dim-mid {
  flex: 1;
}

.pc-dim-name {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
  letter-spacing: 2rpx;
}

.pc-dim-bar-bg {
  height: 5rpx;
  border-radius: 3rpx;
  background: #EFEDE8;
  overflow: hidden;
}

.pc-dim-bar-fill {
  height: 100%;
  border-radius: 3rpx;
}

.pc-dim-score {
  font-size: 28rpx;
  width: 50rpx;
  text-align: right;
}

/* Lucky info */
.pc-lucky {
  display: flex;
  justify-content: space-around;
  margin-bottom: 28rpx;
  border-radius: 16rpx;
  padding: 18rpx 12rpx;
  border: 1rpx solid var(--border);
}

.pc-lucky-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.pc-lucky-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 1rpx solid var(--border);
}

.pc-lucky-num {
  font-size: 34rpx;
  color: var(--text-primary);
}

.pc-lucky-dir {
  font-size: 26rpx;
}

.pc-lucky-text {
  font-size: 22rpx;
  color: var(--text-light);
  letter-spacing: 1rpx;
}

/* Footer */
.pc-footer {
  text-align: center;
}

.pc-footer-text {
  font-size: 22rpx;
  color: var(--text-light);
  letter-spacing: 4rpx;
}

/* ===== Actions ===== */
.poster-actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 28rpx 28rpx;
  border-top: 1rpx solid #eee;
  flex-shrink: 0;
}

.btn-save,
.btn-share {
  flex: 1;
  font-size: 28rpx;
  padding: 18rpx 0;
  border-radius: 48rpx;
  border: none;
  text-align: center;
}

.btn-save {
  background: var(--primary);
  color: #fff;
}

.btn-share {
  background: #07c160;
  color: #fff;
}

.btn-save[disabled],
.btn-share[disabled] {
  background: #ccc;
  color: #999;
}

/* Hidden canvas */
.poster-canvas {
  position: fixed;
  left: -9999px;
  top: 0;
}
