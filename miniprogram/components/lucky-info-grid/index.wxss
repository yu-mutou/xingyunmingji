.lucky-grid {
  margin-bottom: 28rpx;
}

.section-title {
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 20rpx;
  padding-left: 20rpx;
  border-left: 4rpx solid var(--primary);
  letter-spacing: 3rpx;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.grid-item {
  width: calc(50% - 6rpx);
  background: var(--card-bg);
  border-radius: 20rpx;
  border: 1rpx solid var(--border);
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.item-header {
  margin-bottom: 12rpx;
}

.color-swatch {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #EFEDE8;
}

.number-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.direction-icon,
.zodiac-icon {
  font-size: 36rpx;
}

.item-label {
  font-size: 22rpx;
  color: var(--text-light);
  margin-bottom: 4rpx;
  letter-spacing: 2rpx;
}

.item-value {
  font-size: 26rpx;
  color: var(--text-primary);
  letter-spacing: 1rpx;
}
