<view class="dos-donts-section">
  <view class="section-header">
    <view class="accent-line" style="background: {{accentColor}};"></view>
    <view class="section-title" style="color: {{accentColor}};">{{title}}</view>
  </view>
  <view class="item-list">
    <view class="item" wx:for="{{items}}" wx:key="text">
      <view class="item-icon">{{item.icon}}</view>
      <view class="item-content">
        <view class="item-category">{{item.category}}</view>
        <view class="item-text">{{item.text}}</view>
      </view>
    </view>
  </view>
</view>
