.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 48rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-message {
  font-size: 28rpx;
  color: var(--text-light);
  text-align: center;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
}
