.privacy-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2000;
}

.privacy-card {
  width: 640rpx;
  height: 85vh;
  background: #FFFDF9;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  padding: 36rpx 32rpx 28rpx;
  box-sizing: border-box;
}

.privacy-icon {
  font-size: 56rpx;
  text-align: center;
  margin-bottom: 12rpx;
}

.privacy-title {
  font-size: 34rpx;
  color: var(--text-primary);
  text-align: center;
  letter-spacing: 3rpx;
  margin-bottom: 8rpx;
}

.privacy-subtitle {
  font-size: 24rpx;
  color: var(--text-light);
  text-align: center;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.privacy-body {
  flex: 1;
  min-height: 0;
  max-height: 400rpx;
  margin-bottom: 20rpx;
  border-top: 1rpx solid var(--border);
  border-bottom: 1rpx solid var(--border);
  padding: 16rpx 0;
}

.privacy-section {
  margin-bottom: 16rpx;
}

.ps-title {
  font-size: 26rpx;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  letter-spacing: 2rpx;
}

.ps-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.privacy-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.btn-disagree,
.btn-agree {
  flex: 1;
  font-size: 28rpx;
  padding: 18rpx 0;
  border-radius: 48rpx;
  border: none;
  text-align: center;
  letter-spacing: 2rpx;
}

.btn-disagree {
  background: #F5F2EC;
  color: var(--text-light);
}

.btn-agree {
  background: var(--primary);
  color: #fff;
}

.privacy-footer {
  font-size: 22rpx;
  color: var(--text-light);
  text-align: center;
  line-height: 1.6;
}

.link {
  color: var(--primary);
}

/* ===== Full policy popup ===== */
.full-policy-overlay {
  position: fixed;
  top: 0; left: 0;
  width: 100vw; height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2100;
}

.full-policy-card {
  width: 640rpx;
  height: 80vh;
  background: #FFFDF9;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.fph {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #F5F2EC;
  flex-shrink: 0;
}

.fph-title {
  font-size: 30rpx;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}

.fph-close {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: #F5F2EC;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.fph-body {
  flex: 1;
  min-height: 0;
  padding: 24rpx 28rpx 32rpx;
}

.fph-content {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.9;
  white-space: pre-line;
}
