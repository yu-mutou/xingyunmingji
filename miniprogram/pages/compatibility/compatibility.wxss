.mode-toggle {
  display: flex;
  background: #fff;
  border-radius: 48rpx;
  margin-bottom: 32rpx;
  padding: 6rpx;
}

.mode-option {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  border-radius: 48rpx;
  color: var(--text-secondary);
}

.mode-option.active {
  background: var(--primary);
  color: #fff;
  font-weight: 500;
}

.pair-area {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.pair-item {
  width: 180rpx;
  height: 180rpx;
  border-radius: 24rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.pair-emoji {
  font-size: 60rpx;
  margin-bottom: 8rpx;
}

.pair-name {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.pair-heart {
  font-size: 48rpx;
}

.match-btn {
  width: 100%;
  margin-bottom: 32rpx;
}

.match-btn[disabled] {
  background: #ccc;
  color: #999;
}

.picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  z-index: 800;
}

.picker-body {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.picker-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.picker-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.picker-item {
  padding: 16rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  background: #f5f5f5;
}

.result {
  text-align: center;
  padding: 40rpx 24rpx;
}

.result-score {
  font-size: 80rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.result-level {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.result-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 16rpx;
}

.result-advice {
  font-size: 26rpx;
  color: var(--primary);
  line-height: 1.6;
}
