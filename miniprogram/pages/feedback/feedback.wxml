<view class="feedback page-container">
  <view class="card">
    <view class="form-label">反馈内容</view>
    <textarea
      class="feedback-input"
      placeholder="请描述您遇到的问题或建议..."
      maxlength="500"
      bindinput="onContentInput"
      value="{{content}}"
    ></textarea>
    <view class="char-count">{{content.length}}/500</view>
  </view>

  <view class="card">
    <view class="form-label">联系方式（选填）</view>
    <input
      class="contact-input"
      placeholder="微信号/手机号，方便我们回复您"
      bindinput="onContactInput"
      value="{{contact}}"
    />
  </view>

  <button class="submit-btn btn-primary" bindtap="onSubmit" disabled="{{!content.trim()}}">
    提交反馈
  </button>
</view>
