.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.feedback-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.contact-input {
  width: 100%;
  font-size: 28rpx;
  padding: 12rpx 0;
}

.submit-btn {
  width: 100%;
  margin-top: 32rpx;
}

.submit-btn[disabled] {
  background: #ccc;
  color: #999;
}
