<view class="zodiac-detail page-container" wx:if="{{data}}">
  <!-- Horizontal Sign Selector -->
  <scroll-view class="sign-selector" scroll-x="true" enhanced show-scrollbar="{{false}}" scroll-into-view="{{currentKey}}">
    <view class="sign-list">
      <view
        wx:for="{{allSigns}}" wx:key="key"
        id="{{item.key}}"
        class="sign-chip {{currentKey === item.key ? 'active' : ''}}"
        bindtap="onSwitchSign"
        data-key="{{item.key}}"
      >{{item.emoji}}</view>
    </view>
  </scroll-view>

  <!-- Header -->
  <view class="detail-header card">
    <view class="header-icon">{{data.icon}}</view>
    <view class="header-name">{{data.name}}</view>
    <view class="header-meta">
      <view class="meta-tag">{{data.dateRange}}</view>
      <view class="meta-tag">{{data.element}}</view>
      <view class="meta-tag">守护星: {{data.ruler}}</view>
    </view>
  </view>

  <!-- Personality -->
  <view class="card">
    <view class="section-title">性格特点</view>
    <view class="trait-block">
      <view class="trait-label green">优点</view>
      <view class="trait-tags">
        <view wx:for="{{data.strengths}}" wx:key="*this" class="trait-tag green-bg">{{item}}</view>
      </view>
    </view>
    <view class="trait-block">
      <view class="trait-label red">缺点</view>
      <view class="trait-tags">
        <view wx:for="{{data.weaknesses}}" wx:key="*this" class="trait-tag red-bg">{{item}}</view>
      </view>
    </view>
    <view class="personality-text">{{data.personality}}</view>
  </view>

  <!-- Love Style -->
  <view class="card">
    <view class="section-title">恋爱风格</view>
    <view class="section-text">{{data.loveStyle}}</view>
  </view>

  <!-- Career Style -->
  <view class="card">
    <view class="section-title">事业特质</view>
    <view class="section-text">{{data.careerStyle}}</view>
  </view>

  <!-- Compatible Signs -->
  <view class="card">
    <view class="section-title">适配星座</view>
    <view class="compat-list">
      <view
        wx:for="{{compatibleList}}" wx:key="key"
        class="compat-item"
        bindtap="onSwitchSign"
        data-key="{{item.key}}"
      >{{item.icon}} {{item.name}}</view>
    </view>
  </view>
</view>
