/* ===== Horizontal Sign Selector ===== */
.sign-selector {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 16rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.sign-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.sign-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #fff;
  font-size: 30rpx;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.sign-chip.active {
  background: var(--primary);
  transform: scale(1.1);
}

/* ===== Detail Content ===== */
.detail-header {
  text-align: center;
  padding: 40rpx 24rpx;
}

.header-icon {
  font-size: 72rpx;
  margin-bottom: 12rpx;
}

.header-name {
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.header-meta {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.meta-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 24rpx;
  background: rgba(123, 97, 255, 0.08);
  color: var(--primary);
}

.trait-block {
  margin-bottom: 16rpx;
}

.trait-label {
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.trait-label.green { color: var(--green); }
.trait-label.red { color: var(--red); }

.trait-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.trait-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.trait-tag.green-bg {
  background: rgba(82, 196, 26, 0.08);
  color: var(--green);
}

.trait-tag.red-bg {
  background: rgba(245, 63, 63, 0.08);
  color: var(--red);
}

.personality-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  margin-top: 8rpx;
}

.section-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.compat-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.compat-item {
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  background: rgba(123, 97, 255, 0.06);
  color: var(--primary);
  font-size: 26rpx;
}
