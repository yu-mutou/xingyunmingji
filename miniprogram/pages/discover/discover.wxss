.discover {
  padding-top: 12rpx;
}

/* ===== Section ===== */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  color: var(--text-primary);
  letter-spacing: 3rpx;
}

.section-more {
  font-size: 26rpx;
  color: var(--primary);
  letter-spacing: 2rpx;
}

/* ===== Horizontal Scroll ===== */
.zodiac-scroll {
  width: 100%;
  white-space: nowrap;
}

.zodiac-list {
  display: inline-flex;
  gap: 22rpx;
  padding: 4rpx 0;
}

.zodiac-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 130rpx;
  flex-shrink: 0;
}

.zodiac-circle {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #F5F2EC;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--border);
}

.zodiac-circle.active {
  background: rgba(123, 97, 255, 0.06);
  border-color: var(--primary);
}

.zodiac-emoji {
  font-size: 34rpx;
}

.zodiac-name {
  font-size: 26rpx;
  color: var(--text-primary);
  margin-bottom: 2rpx;
  letter-spacing: 1rpx;
}

.zodiac-date {
  font-size: 22rpx;
  color: var(--text-light);
}

/* ===== Compatibility Card ===== */
.compat-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.compat-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.compat-icon {
  font-size: 48rpx;
}

.compat-title {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  letter-spacing: 2rpx;
}

.compat-desc {
  font-size: 26rpx;
  color: var(--text-light);
}

.compat-btn {
  padding: 16rpx 36rpx;
  border-radius: 48rpx;
  background: var(--primary);
  color: #fff;
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

/* ===== Shake Divination ===== */
.shake-card {
  text-align: center;
}

.shake-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.shake-icon {
  font-size: 64rpx;
  animation: wobble 3s ease-in-out infinite;
}

@keyframes wobble {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(8deg); }
  75% { transform: rotate(-8deg); }
}

.shake-label {
  font-size: 32rpx;
  color: var(--text-primary);
  letter-spacing: 3rpx;
}

.shake-hint {
  font-size: 26rpx;
  color: var(--text-light);
}

.shake-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  animation: popIn 0.5s ease;
}

@keyframes popIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.result-emoji {
  font-size: 72rpx;
  animation: bounce 0.6s ease;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-14rpx); }
}

.result-title {
  font-size: 34rpx;
  color: var(--primary);
  letter-spacing: 3rpx;
}

.result-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  padding: 0 12rpx;
}

.result-retry {
  font-size: 26rpx;
  color: var(--primary);
  padding: 8rpx 28rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(123, 97, 255, 0.2);
  letter-spacing: 2rpx;
}

/* ===== Daily Tips ===== */
.tips-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
}

.tip-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: var(--primary);
  margin-top: 6rpx;
  flex-shrink: 0;
  opacity: 0.4;
}

.tip-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}
