.about-card {
  text-align: center;
  padding: 40rpx 24rpx;
  margin-bottom: 20rpx;
}

.app-icon {
  font-size: 80rpx;
  margin-bottom: 12rpx;
}

.app-name {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.app-version {
  font-size: 24rpx;
  color: var(--text-light);
  margin-bottom: 16rpx;
}

.app-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}

.menu-section {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 24rpx;
}

.menu-item:not(:last-child) {
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-label {
  font-size: 28rpx;
  color: var(--text-primary);
}

.menu-arrow {
  font-size: 26rpx;
  color: var(--text-light);
}

.footer-text {
  text-align: center;
  font-size: 24rpx;
  color: var(--text-light);
  padding-top: 40rpx;
}

/* Modal */
.modal-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-body {
  width: 640rpx;
  height: 80vh;
  background: #fff;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.modal-scroll {
  flex: 1;
  min-height: 0;
  padding: 24rpx 28rpx 36rpx;
}

.modal-content {
  font-size: 26rpx;
  line-height: 1.8;
  color: var(--text-secondary);
  white-space: pre-line;
}
